---
import Layout from "../layouts/Layout.astro";
---

<Layout title="eddn.dev — Eduardo Alonso">
	<main class="max-w-5xl mx-auto px-6 py-24 sm:py-32 lg:py-40">
		<header class="space-y-8">
			<div class="flex items-center gap-3">
				<div
					class="w-3 h-3 bg-brand-500 rounded-full shadow-[0_0_10px_rgba(139,92,246,0.5)]"
				>
				</div>
				<span
					class="font-mono text-xs uppercase tracking-[0.3em] text-slate-500"
					>Kernel Version 1.0.0</span
				>
			</div>

			<h1
				class="text-6xl sm:text-8xl font-black tracking-tighter text-slate-900 leading-[0.85]"
			>
				EDD <br />
				<span
					class="text-brand-500 underline decoration-brand-100 decoration-8 underline-offset-8"
					>JOURNAL.</span
				>
			</h1>

			<p
				class="text-xl sm:text-2xl text-slate-600 font-light leading-relaxed max-w-2xl"
			>
				Un espacio personal dedicado a la <span
					class="text-slate-900 font-medium"
					>ingeniería de software</span
				>, la resolución de problemas algorítmicos y reflexiones sobre
				el desarrollo de productos.
			</p>

			<div class="flex flex-wrap gap-4 pt-4">
				<a
					href="/blog"
					class="px-6 py-3 bg-brand-500 text-white font-bold rounded-full hover:bg-brand-600 transition-colors shadow-lg shadow-brand-500/20"
				>
					Explorar Blog
				</a>
				<a
					href="/trajectory"
					class="px-6 py-3 bg-white text-slate-900 font-bold rounded-full border border-slate-200 hover:bg-slate-50 transition-colors"
				>
					Ver Trayectoria
				</a>
			</div>
		</header>

		<section class="mt-32 grid grid-cols-1 md:grid-cols-2 gap-12">
			<a
				href="/leetcode"
				class="p-8 bg-white border border-slate-100 rounded-none shadow-sm space-y-4 hover:border-brand-500/50 hover:shadow-md transition-all group"
			>
				<span
					class="text-xs font-mono text-brand-500 font-bold uppercase tracking-widest"
					>[ LEETCODE ]</span
				>
				<h3
					class="text-2xl font-bold text-slate-900 group-hover:text-brand-500 transition-colors"
				>
					Soluciones Optimizadas
				</h3>
				<p class="text-slate-600">
					Registro de retos resueltos, analizando complejidad temporal
					y espacial.
				</p>
			</a>
			<div
				class="p-8 bg-white border border-slate-100 rounded-none shadow-sm space-y-4 opacity-60"
			>
				<span
					class="text-xs font-mono text-slate-400 font-bold uppercase tracking-widest"
					>[ LAB ]</span
				>
				<h3 class="text-2xl font-bold text-slate-900">Experimentos</h3>
				<p class="text-slate-600">
					Prototipos rápidos y pruebas de concepto sobre nuevas
					tecnologías.
				</p>
			</div>
		</section>
	</main>
</Layout>
