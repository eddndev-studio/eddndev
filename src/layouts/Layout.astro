---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { ClientRouter } from "astro:transitions";

interface Props {
	title?: string;
	description?: string;
	hreflangs?: Array<{ lang: string; href: string }>;
	prevUrl?: string;
	nextUrl?: string;
}

const {
	title = "eddn.dev — Personal Journal",
	description = "Ingeniería de software, trayectoria y pensamientos personales de Eduardo Alonso.",
	hreflangs = [],
	prevUrl,
	nextUrl,
} = Astro.props;
---

<!doctype html>
<html lang="es" class="overflow-x-hidden">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/x-icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />

		<title>{title}</title>
		<meta name="description" content={description} />

		<!-- Canonical URL -->
		<link rel="canonical" href={new URL(Astro.url.pathname, Astro.site)} />

		<!-- Hreflang Tags -->
		{
			hreflangs.map(({ lang, href }) => (
				<link
					rel="alternate"
					hreflang={lang}
					href={new URL(href, Astro.site)}
				/>
			))
		}

		<!-- Pagination SEO -->
		{prevUrl && <link rel="prev" href={new URL(prevUrl, Astro.site)} />}
		{nextUrl && <link rel="next" href={new URL(nextUrl, Astro.site)} />}

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={Astro.url} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:site_name" content="eddn.dev" />
		<meta property="og:image" content={`https://og.eddn.dev/generate?title=${encodeURIComponent(title)}`} />

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={Astro.url} />
		<meta property="twitter:title" content={title} />
		<meta property="twitter:description" content={description} />
		<meta property="twitter:image" content={`https://og.eddn.dev/generate?title=${encodeURIComponent(title)}`} />

		<ClientRouter />

		<!-- Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap"
			rel="stylesheet"
		/>

		<!-- KaTeX for math rendering -->
		<link
			rel="stylesheet"
			href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css"
			integrity="sha384-n8MVd4RsNIU0tAv4ct0nTaAbDJwPJzDEaqSD1odI+WdtXRGWt2kTvGFasHpSy3SV"
			crossorigin="anonymous"
		/>
	</head>
	<body class="selection:bg-brand-500/30 overflow-x-hidden relative">
		<div id="ambient-blobs" class="pointer-events-none absolute left-0 top-0 w-full h-full z-[-1] overflow-hidden"></div>
		<Header />
		<main class="pt-16">
			<slot />
		</main>
		<Footer />

		<script>
			import Lenis from "lenis";
			import { gsap } from "gsap";
			import { ScrollTrigger } from "gsap/ScrollTrigger";

			gsap.registerPlugin(ScrollTrigger);

			let lenis: Lenis;

			const update = (time: number) => {
				lenis?.raf(time * 1000);
			};

			function generateBlobs() {
				const container = document.getElementById("ambient-blobs");
				if (!container) return;

				// Clear existing blobs (important for view transitions)
				container.innerHTML = '';

				const pageHeight = document.documentElement.scrollHeight;
				// Add roughly one blob every 1200px of content
				const blobCount = Math.max(2, Math.floor(pageHeight / 1200));

				const colors = ['bg-brand-300', 'bg-brand-500', 'bg-slate-300'];

				for (let i = 0; i < blobCount; i++) {
					const blob = document.createElement("div");
					
					// Deterministic size pattern between 450px and 650px
					const sizes = [450, 600, 500, 650, 550];
					const size = sizes[i % sizes.length];
					
					// Deterministic color pattern
					const color = colors[i % colors.length];
					
					// Deterministic vertical jitter to break perfect symmetry
					const jitters = [100, -150, 200, -100, 150];
					const topPosition = (pageHeight / blobCount) * i + jitters[i % jitters.length];
					
					// Alternate between left and right sides
					const isLeft = i % 2 === 0;
					
					// Predictable horizontal offset to vary how much of the blob is visible
					const horizontalOffsets = [3, 2.5, 4, 3.5, 2.8];
					const offsetDivisor = horizontalOffsets[i % horizontalOffsets.length];
					const horizontalPosition = isLeft 
						? `left: -${size / offsetDivisor}px;` 
						: `right: -${size / offsetDivisor}px;`;

					blob.className = `absolute rounded-full opacity-20 blur-[120px] ${color}`;
					blob.style.width = `${size}px`;
					blob.style.height = `${size}px`;
					blob.style.top = `${Math.max(0, topPosition)}px`;
					blob.style.cssText += horizontalPosition;

					container.appendChild(blob);
				}
			}

			function init() {
				// Initialize Lenis
				lenis = new Lenis({
					duration: 1.2,
					easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
					touchMultiplier: 2,
				});

				// GSAP & Lenis integration
				lenis.on("scroll", ScrollTrigger.update);
				gsap.ticker.add(update);
				gsap.ticker.lagSmoothing(0);

				// Global Animations
				animateContent();

				// Ambient Background Blobs
				// Use setTimeout to ensure the DOM is fully painted and scrollHeight is accurate
				setTimeout(generateBlobs, 100);
			}

			function animateContent() {
				// 1. Hero / Header Reveal
				// Targets direct children of the main header
				const heroElements =
					document.querySelectorAll("main > header > *");
				if (heroElements.length) {
					gsap.fromTo(
						heroElements,
						{ y: 20, opacity: 0 },
						{
							y: 0,
							opacity: 1,
							duration: 0.8,
							stagger: 0.1,
							ease: "power3.out",
							clearProps: "all",
						},
					);
				}

				// 2. Grid Items (Blog Posts, Cards)
				// Targets children of any generic grid container
				const gridItems = document.querySelectorAll(
					".grid > article, .grid > a, .grid > div",
				);
				if (gridItems.length) {
					gsap.fromTo(
						gridItems,
						{ y: 10 },
						{
							y: 0,
							duration: 0.4,
							stagger: 0.05,
							ease: "power2.out",
							delay: 0.1,
							clearProps: "all",
						},
					);
				}

				// 3. List/Table Items (LeetCode Rows, Trajectory Timeline)
				const listItems = document.querySelectorAll(
					"tbody > tr, .space-y-12 > .relative",
				);
				if (listItems.length) {
					gsap.fromTo(
						listItems,
						{ x: -10, opacity: 0 },
						{
							x: 0,
							opacity: 1,
							duration: 0.5,
							stagger: 0.05,
							ease: "power2.out",
							delay: 0.3,
							clearProps: "all",
						},
					);
				}
			}

			function cleanup() {
				if (lenis) {
					lenis.destroy();
				}
				gsap.ticker.remove(update);
				ScrollTrigger.getAll().forEach((t) => t.kill());
			}

			document.addEventListener("astro:page-load", init);
			document.addEventListener("astro:before-swap", cleanup);
		</script>
	</body>
</html>
