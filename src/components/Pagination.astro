---
import type { Page } from "astro";

interface Props {
    page: Page<any>;
}

const { page } = Astro.props;

// Helper to ensure trailing slash
const ensureSlash = (path: string) => path.endsWith('/') ? path : `${path}/`;

// Helper to construct URL for any page number
const getPageUrl = (pageNum: number) => {
    const currentPath = Astro.url.pathname;
    let cleanBase = currentPath.replace(/\/(\d+)\/?$/, "").replace(/\/$/, "");
    if (!cleanBase) cleanBase = "/";

    if (pageNum === 1) {
        return cleanBase === "/" ? "/" : `${cleanBase}/`;
    }
    return `${cleanBase === "/" ? "" : cleanBase}/${pageNum}/`;
};

const pad = (n: number) => String(n).padStart(2, '0');
const progress = (page.currentPage / page.lastPage) * 100;
---

{
    page.lastPage > 1 && (
        <nav class="mt-20 space-y-6">
            {/* Label + counter */}
            <div class="flex items-center justify-between border-b border-slate-200 pb-4">
                <span class="font-mono text-xs uppercase tracking-widest text-slate-400">
                    Page
                </span>
                <span class="font-mono text-xs tracking-widest text-slate-400">
                    {pad(page.currentPage)} / {pad(page.lastPage)}
                </span>
            </div>

            {/* Progress bar */}
            <div class="h-0.5 bg-slate-200 overflow-hidden">
                <div
                    class="h-full bg-brand-500 transition-all duration-500 ease-out"
                    style={`width: ${progress}%`}
                />
            </div>

            {/* Navigation row */}
            <div class="flex items-center justify-between">
                {/* Previous */}
                <div class="flex-1">
                    {page.url.prev ? (
                        <a
                            href={ensureSlash(page.url.prev)}
                            class="group inline-flex items-center gap-3 font-mono text-xs font-bold uppercase tracking-widest text-slate-900 hover:text-brand-600 transition-colors"
                        >
                            <span class="inline-block w-6 h-px bg-slate-400 group-hover:bg-brand-500 group-hover:w-10 transition-all duration-300" />
                            Prev
                        </a>
                    ) : (
                        <span class="inline-flex items-center gap-3 font-mono text-xs uppercase tracking-widest text-slate-300 cursor-default">
                            <span class="inline-block w-6 h-px bg-slate-200" />
                            Prev
                        </span>
                    )}
                </div>

                {/* Page numbers — desktop */}
                <div class="hidden sm:flex items-center gap-1">
                    {Array.from({ length: page.lastPage }, (_, i) => i + 1).map(
                        (pageNum) => (
                            <a
                                href={getPageUrl(pageNum)}
                                class={`group relative px-3 py-2 font-mono text-xs tracking-widest transition-colors ${
                                    pageNum === page.currentPage
                                        ? "text-brand-600 font-bold"
                                        : "text-slate-400 hover:text-slate-900"
                                }`}
                            >
                                {pad(pageNum)}
                                {/* Active underline */}
                                {pageNum === page.currentPage && (
                                    <span class="absolute bottom-0 left-3 right-3 h-0.5 bg-brand-500" />
                                )}
                            </a>
                        ),
                    )}
                </div>

                {/* Next */}
                <div class="flex-1 flex justify-end">
                    {page.url.next ? (
                        <a
                            href={ensureSlash(page.url.next)}
                            class="group inline-flex items-center gap-3 font-mono text-xs font-bold uppercase tracking-widest text-slate-900 hover:text-brand-600 transition-colors"
                        >
                            Next
                            <span class="inline-block w-6 h-px bg-slate-400 group-hover:bg-brand-500 group-hover:w-10 transition-all duration-300" />
                        </a>
                    ) : (
                        <span class="inline-flex items-center gap-3 font-mono text-xs uppercase tracking-widest text-slate-300 cursor-default">
                            Next
                            <span class="inline-block w-6 h-px bg-slate-200" />
                        </span>
                    )}
                </div>
            </div>
        </nav>
    )
}
