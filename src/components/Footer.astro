---
import { useTranslations } from '../i18n/ui';

const currentYear = new Date().getFullYear();
const lang = (Astro.currentLocale as keyof typeof import('../i18n/ui').ui) || 'en';
const t = useTranslations(lang);
---

<footer class="bg-white dark:bg-[#010208] text-slate-900 dark:text-slate-100 min-h-[100dvh] flex flex-col justify-center py-24 lg:py-32 border-t border-slate-200 dark:border-slate-800 overflow-hidden relative z-20">
    <canvas id="footer-gol" class="absolute inset-0 w-full h-full opacity-30 dark:opacity-10 pointer-events-none"></canvas>
    <div class="mx-auto max-w-7xl px-6 relative z-10">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-20">
            
            <!-- Site Map -->
            <div class="space-y-12 hidden lg:block">
                <h2 class="text-xs font-mono text-brand-500 tracking-widest mb-8">{t('footer.explore')}</h2>
                
                <ul class="space-y-8">
                    <li class="group border-b border-slate-100 dark:border-slate-800 pb-4 hover:border-brand-500 transition-colors">
                        <a href={lang === 'es' ? "/es/blog/" : "/blog/"} class="flex items-baseline justify-between w-full">
                            <span class="text-2xl lg:text-3xl font-bold text-slate-700 dark:text-slate-300 group-hover:text-slate-900 dark:group-hover:text-white transition-colors">{t('nav.blog')}</span>
                            <span class="text-sm font-mono text-slate-400 group-hover:text-brand-500 transition-colors">{t('footer.blog_desc')}</span>
                        </a>
                    </li>
                    <li class="group border-b border-slate-100 dark:border-slate-800 pb-4 hover:border-brand-500 transition-colors">
                        <a href={lang === 'es' ? "/es/articles/" : "/articles/"} class="flex items-baseline justify-between w-full">
                            <span class="text-2xl lg:text-3xl font-bold text-slate-700 dark:text-slate-300 group-hover:text-slate-900 dark:group-hover:text-white transition-colors">{t('nav.articles')}</span>
                            <span class="text-sm font-mono text-slate-400 group-hover:text-brand-500 transition-colors">{t('footer.articles_desc')}</span>
                        </a>
                    </li>
                    <li class="group border-b border-slate-100 dark:border-slate-800 pb-4 hover:border-brand-500 transition-colors">
                        <a href={lang === 'es' ? "/es/leetcode/" : "/leetcode/"} class="flex items-baseline justify-between w-full">
                            <span class="text-2xl lg:text-3xl font-bold text-slate-700 dark:text-slate-300 group-hover:text-slate-900 dark:group-hover:text-white transition-colors">{t('nav.leetcode')}</span>
                            <span class="text-sm font-mono text-slate-400 group-hover:text-brand-500 transition-colors">{t('footer.leetcode_desc')}</span>
                        </a>
                    </li>
                    <li class="group border-b border-slate-100 dark:border-slate-800 pb-4 hover:border-brand-500 transition-colors">
                        <a href={lang === 'es' ? "/es/trajectory/" : "/trajectory/"} class="flex items-baseline justify-between w-full">
                            <span class="text-2xl lg:text-3xl font-bold text-slate-700 dark:text-slate-300 group-hover:text-slate-900 dark:group-hover:text-white transition-colors">{t('nav.trajectory')}</span>
                            <span class="text-sm font-mono text-slate-400 group-hover:text-brand-500 transition-colors">{t('footer.trajectory_desc')}</span>
                        </a>
                    </li>
                </ul>
            </div>

            <!-- CTA / Contact -->
            <div class="flex flex-col justify-between h-full">
                 <div>
                    <h3 class="text-5xl lg:text-7xl font-black tracking-tighter leading-[0.9] mb-8 uppercase" set:html={t('footer.talk_title')}>
                    </h3>
                    <p class="text-slate-600 dark:text-slate-400 text-lg mb-12">
                        {t('footer.talk_desc')}
                    </p>
                 </div>

                 <div class="flex flex-col sm:flex-row gap-6">
                    <!-- Primary CTA -->
                    <a href="#" id="email-cta" class="group relative inline-flex items-center justify-center px-8 py-4 bg-brand-500 text-white font-bold rounded-full overflow-hidden transition-transform hover:scale-105 shadow-lg shadow-brand-500/20">
                        <span class="relative z-10 group-hover:text-brand-100 transition-colors">{t('footer.start_conversation')}</span>
                    </a>
                 </div>
            </div>

        </div>

        <!-- Minimal Footer Info -->
        <div class="mt-24 pt-8 border-t border-slate-100 dark:border-slate-800 flex flex-col sm:flex-row justify-between items-center text-xs text-slate-500 font-mono">
            <span>&copy; {currentYear} EDDN.DEV. {t('footer.rights')}</span>
            <div class="flex flex-wrap gap-4 mt-4 sm:mt-0 justify-center">
                <a href="https://github.com/eddndev" target="_blank" rel="noopener noreferrer" class="hover:text-brand-600 transition-colors">GITHUB</a>
                <a href="https://www.linkedin.com/in/eddndev" target="_blank" rel="noopener noreferrer" class="hover:text-brand-600 transition-colors">LINKEDIN</a>
                <a href="https://x.com/eddndev" target="_blank" rel="noopener noreferrer" class="hover:text-brand-600 transition-colors">X</a>
                <a href="https://instagram.com/eddn.dev" target="_blank" rel="noopener noreferrer" class="hover:text-brand-600 transition-colors">INSTAGRAM</a>
                <a href="https://eddndev.com" target="_blank" rel="noopener noreferrer" class="hover:text-brand-600 transition-colors">EDDNDEV.COM</a>
                <a href="https://achrony.me" target="_blank" rel="noopener noreferrer" class="hover:text-brand-600 transition-colors">ACHRONY.ME</a>
            </div>
        </div>
    </div>
</footer>

<script>
    import GameOfLife from "../lib/GameOfLife";

    let gol: GameOfLife | null = null;

    function initFooterVisual() {
        const canvas = document.getElementById('footer-gol') as HTMLCanvasElement;
        if (!canvas) return;

        // Cleanup existing instance if any
        if (gol) {
            gol.destroy();
        }

        // Initialize
        const isDark = document.documentElement.classList.contains('dark');
        gol = new GameOfLife(canvas, isDark ? '#334155' : '#94a3b8');
        gol.init();
        
        // Email Obfuscation Logic (Bypasses Cloudflare Email Protection)
        const emailCta = document.getElementById('email-cta');
        if (emailCta) {
            emailCta.addEventListener('click', (e) => {
                e.preventDefault();
                const user = 'contacto';
                const domain = 'eddndev.com';
                window.location.href = `mailto:${user}@${domain}`;
            });
            // Optional: Set href on hover so status bar looks legit (but might trigger CF if it scans DOM aggressively, though usually it scans static HTML)
            emailCta.addEventListener('mouseover', () => {
                 const user = 'contacto';
                 const domain = 'eddndev.com';
                 emailCta.setAttribute('href', `mailto:${user}@${domain}`);
            });
        }
    }

    function cleanupFooterVisual() {
        if (gol) {
            gol.destroy();
            gol = null;
        }
    }

    // Initialize on every page load (initial + navigation)
    document.addEventListener('astro:page-load', initFooterVisual);
    
    // Cleanup before swapping content
    document.addEventListener('astro:before-swap', cleanupFooterVisual);
</script>
