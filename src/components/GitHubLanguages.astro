---
import { useTranslations } from "../i18n/ui";

interface Props {
  lang: 'en' | 'es';
}

interface LanguageStats {
  name: string;
  percent: number;
  color: string;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const USERNAME = "eddndev";
const GITHUB_TOKEN = import.meta.env.GITHUB_TOKEN;

let languages: LanguageStats[] = [];

// Custom Brand Palette (Violet/Slate mix)
const brandPalette = [
    "#7c3aed", // brand-600
    "#a78bfa", // brand-400
    "#475569", // slate-600
    "#c4b5fd", // brand-300
    "#94a3b8", // slate-400
    "#ddd6fe", // brand-200
    "#64748b"  // slate-500
];

if (GITHUB_TOKEN) {
  try {
    const query = `
      query {
        user(login: "${USERNAME}") {
          repositories(ownerAffiliations: OWNER, first: 100) {
            nodes {
              languages(first: 10, orderBy: {field: SIZE, direction: DESC}) {
                edges {
                  size
                  node { name }
                }
              }
            }
          }
        }
      }
    `;

    const response = await fetch("https://api.github.com/graphql", {
      method: "POST",
      headers: { 
        "Authorization": `Bearer ${GITHUB_TOKEN}`,
        "Content-Type": "application/json",
        "User-Agent": "Astro-Build"
      },
      body: JSON.stringify({ query })
    });

    const json = await response.json();
    
    if (json.data?.user?.repositories?.nodes) {
      const repos = json.data.user.repositories.nodes;
      const langMap: Record<string, number> = {};
      
      repos.forEach((repo: any) => {
        repo.languages.edges.forEach((edge: any) => {
          const { name } = edge.node;
          langMap[name] = (langMap[name] || 0) + edge.size;
        });
      });

      const totalSize = Object.values(langMap).reduce((a, b) => a + b, 0);
      languages = Object.entries(langMap)
        .map(([name, size], index) => ({
          name,
          percent: parseFloat(((size / totalSize) * 100).toFixed(1)),
          color: '' 
        }))
        .filter(l => !['HTML', 'CSS'].includes(l.name))
        .sort((a, b) => b.percent - a.percent)
        .slice(0, 7)
        .map((l, i) => ({ ...l, color: brandPalette[i % brandPalette.length] }));
    }
  } catch (e) {
    console.warn("GitHub GraphQL Fetch failed", e);
  }
}

// Final Fallback if everything fails
if (languages.length === 0) {
    languages = [
        { name: "TypeScript", percent: 45, color: brandPalette[0] },
        { name: "Rust", percent: 30, color: brandPalette[1] },
        { name: "Python", percent: 15, color: brandPalette[2] },
        { name: "Other", percent: 10, color: brandPalette[3] }
    ];
}

const totalPercent = languages.reduce((acc, curr) => acc + curr.percent, 0);
---

<section class="w-full py-8 border-t border-slate-200">
  <div class="flex items-center justify-between mb-6">
    <div class="flex items-baseline gap-4">
      <h3 class="text-xl font-bold text-slate-900">
        {t('languages.most_used')}
      </h3>
      <span class="text-xs font-mono text-slate-500">
        {t('languages.stats_label')}
      </span>
    </div>
  </div>

  <div class="bg-slate-50 p-6 border border-slate-100">
      <div class="flex h-3 w-full overflow-hidden rounded-none bg-slate-200 mb-6">
        {languages.map((lang) => (
          <div
            style={{ width: `${(lang.percent / totalPercent) * 100}%`, backgroundColor: lang.color }}
            class="h-full first:rounded-l-none last:rounded-r-none transition-all duration-500 hover:opacity-90 relative group"
          >
             <div class="absolute bottom-full mb-2 left-1/2 -translate-x-1/2 hidden group-hover:block bg-slate-900 text-white text-xs font-bold py-1 px-2 pointer-events-none whitespace-nowrap z-10">
                {lang.name} {lang.percent}%
                <div class="absolute top-full left-1/2 -translate-x-1/2 border-4 border-transparent border-t-slate-900"></div>
             </div>
          </div>
        ))}
      </div>

      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4">
        {languages.map((lang) => (
          <div class="flex items-center gap-2">
            <div 
                class="w-3 h-3 rounded-full" 
                style={{ backgroundColor: lang.color }}
            ></div>
            <div class="flex flex-col">
                <span class="text-xs font-bold text-slate-700 leading-none">
                    {lang.name}
                </span>
                <span class="text-[10px] font-mono text-slate-500 mt-1">
                    {lang.percent}%
                </span>
            </div>
          </div>
        ))}
      </div>
  </div>
</section>
