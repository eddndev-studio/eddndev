---
interface ContributionDay {
  date: string;
  count: number;
  level: 0 | 1 | 2 | 3 | 4;
  isFuture: boolean;
}

const USERNAME = "eddndev";
let totalSubmissions = 0;
let weeks: ContributionDay[][] = [];

// New stats
let ranking = 0;
let hardSolved = 0;
let mediumSolved = 0;
let easySolved = 0;
let acceptanceRate = 0;
let totalSolved = 0;

const getLevel = (count: number): 0 | 1 | 2 | 3 | 4 => {
  if (count === 0) return 0;
  if (count === 1) return 1;
  if (count === 2) return 2;
  if (count <= 4) return 3;
  return 4;
};

// 1. FETCH DATA (Server Side)
try {
  const response = await fetch(`https://leetcode-stats-api.herokuapp.com/${USERNAME}`);
  if (response.ok) {
    const data = await response.json();
    if (data.status === 'success') {
       // Extract new stats
       ranking = data.ranking;
       hardSolved = data.hardSolved;
       mediumSolved = data.mediumSolved;
       easySolved = data.easySolved;
       acceptanceRate = data.acceptanceRate;
       totalSolved = data.totalSolved;

       if (data.submissionCalendar) {
          // It can be an object OR a stringified JSON depending on the proxy
          const rawCalendar = typeof data.submissionCalendar === 'string' 
            ? JSON.parse(data.submissionCalendar) 
            : data.submissionCalendar;
          
          const normalizedMap = new Map<string, number>();
          const now = new Date();
          now.setHours(0, 0, 0, 0);

          Object.entries(rawCalendar).forEach(([ts, count]) => {
             // LeetCode returns timestamps in seconds.
             // We filter out any submission that claims to be in the future relative to server time.
             const date = new Date(parseInt(ts) * 1000);
             date.setHours(0, 0, 0, 0);
             
             if (date > now) return;

             const dateStr = date.toISOString().split('T')[0];
             normalizedMap.set(dateStr, (normalizedMap.get(dateStr) || 0) + (count as number));
          });

          const end = new Date(now);
          // Calculate start: Go back ~1 year (52 weeks)
          const start = new Date(end);
          start.setDate(start.getDate() - 365);
          
          // ALIGN TO SUNDAY: Go back to the previous Sunday (or stay if today is Sunday)
          // getDay(): 0 = Sunday, 1 = Monday, ...
          start.setDate(start.getDate() - start.getDay());

          let current = new Date(start);
          // Reset hours to avoid DST issues affecting day loop
          current.setHours(0, 0, 0, 0);
          
          let week: ContributionDay[] = [];
          let yearTotal = 0;

          // Loop until we pass 'end' or finish the last week
          while (current <= end || week.length > 0) {
            const dateStr = current.toISOString().split('T')[0];
            // Only count submissions if current date is within valid range (<= end)
            // But we might need to pad the rest of the week with empty cells if we passed 'end'
            
            const isFuture = current > end;
            const count = !isFuture ? (normalizedMap.get(dateStr) || 0) : 0;
            
            if (!isFuture) {
                 yearTotal += count;
            }

            week.push({ 
                date: current.toISOString(), 
                count: count, 
                level: getLevel(count),
                isFuture
            });

            if (week.length === 7) { 
                weeks.push(week); 
                week = []; 
            }
            
            // Safety break if we went too far past end and finished the week
            if (current > end && week.length === 0) break;
            
            current.setDate(current.getDate() + 1);
          }
          totalSubmissions = yearTotal;
       }
    }
  }
} catch (e) {
  console.warn("LeetCode server-side fetch failed");
}

const getServerColor = (level: number) => {
  switch (level) {
    case 1: return 'bg-brand-300';
    case 2: return 'bg-brand-500';
    case 3: return 'bg-brand-700';
    case 4: return 'bg-brand-900';
    default: return 'bg-slate-200/50';
  }
};
---

<section class="w-full py-16 border-t border-slate-200">
  <div class="flex items-center justify-between mb-8">
    <div class="flex items-baseline gap-4">
      <h3 class="text-2xl font-bold text-slate-900">
        Actividad en LeetCode
      </h3>
      <span class="text-sm font-mono text-slate-500">
        @{USERNAME}
      </span>
    </div>
    
    <div id="lc-total" class="hidden sm:block text-sm text-slate-500 font-medium transition-opacity duration-300">
      {weeks.length > 0 
        ? `${totalSubmissions} envíos en el último año`
        : 'Cargando datos...'}
    </div>
  </div>

  <!-- Dashboard -->
  {weeks.length > 0 ? (
    <div class="grid grid-cols-1 md:grid-cols-12 gap-6 mb-12">
        <!-- Ranking Card -->
        <div class="md:col-span-4 bg-slate-50 p-6 rounded-none border border-slate-100 flex flex-col justify-between relative overflow-hidden group">
            <div class="absolute top-0 right-0 p-4 opacity-10 group-hover:opacity-20 transition-opacity pointer-events-none">
                <svg class="w-24 h-24 text-slate-900" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z" />
                </svg>
            </div>
            <div>
                <span class="text-xs font-mono font-medium text-slate-500 uppercase tracking-wider">Ranking Global</span>
                <div class="mt-2 text-3xl lg:text-4xl font-bold text-slate-900 font-mono tracking-tight">
                    {ranking.toLocaleString()}
                </div>
            </div>
             <div class="mt-4 inline-flex items-center gap-2 text-sm font-medium text-slate-600">
                <span class="inline-block w-2 h-2 rounded-none bg-brand-500"></span>
                Top Tier
            </div>
        </div>

        <!-- Stats & Quality Card -->
        <div class="md:col-span-8 bg-slate-50 p-6 rounded-none border border-slate-100 flex flex-col justify-center">
            <div class="flex items-end justify-between mb-2">
                <div>
                     <span class="text-xs font-mono font-medium text-slate-500 uppercase tracking-wider">Calidad de Soluciones</span>
                     <div class="mt-1 text-xl font-bold text-slate-900">
                        {hardSolved} <span class="text-slate-400 text-sm font-normal">Problemas Hard</span>
                     </div>
                </div>
                 <div class="text-right">
                    <div class="text-xs font-mono text-slate-500">Acceptance Rate</div>
                    <div class="font-bold text-slate-900">{acceptanceRate}%</div>
                </div>
            </div>
            
            <!-- Progress Bar for Hard Problems -->
             <div class="relative w-full h-3 bg-slate-200 rounded-none overflow-hidden mb-4">
                 <div class="absolute top-0 left-0 h-full bg-slate-900 transition-all duration-1000" style={`width: ${Math.min((hardSolved / 50) * 100, 100)}%`}></div>
            </div>
            
            <div class="grid grid-cols-3 gap-4 mt-2">
                <div class="bg-white p-3 rounded-none border border-slate-100 shadow-sm">
                    <div class="text-xs text-slate-500 mb-1">Easy</div>
                    <div class="font-bold text-slate-900">{easySolved}</div>
                </div>
                <div class="bg-white p-3 rounded-none border border-slate-100 shadow-sm">
                    <div class="text-xs text-slate-500 mb-1">Medium</div>
                    <div class="font-bold text-slate-900">{mediumSolved}</div>
                </div>
                 <div class="bg-brand-50 p-3 rounded-none border border-brand-100 shadow-sm ring-1 ring-brand-200">
                    <div class="text-xs text-brand-700 mb-1 font-bold">Hard</div>
                    <div class="font-bold text-brand-900">{hardSolved}</div>
                </div>
            </div>
        </div>
    </div>
  ) : (
      <div class="h-32 w-full bg-slate-50 rounded-none animate-pulse mb-8 border border-slate-100"></div>
  )}

  <div class="w-full overflow-x-auto pb-2 custom-scrollbar">
      <div id="lc-grid" class="inline-flex gap-[3px] min-w-full justify-end sm:justify-start p-1">
          {weeks.length > 0 ? (
            weeks.map((week) => (
                <div class="flex flex-col gap-[3px]">
                    {week.map((day) => (
                        day.isFuture ? (
                           <div class="w-3 h-3 rounded-full opacity-0"></div>
                        ) : (
                          <div 
                              class={`lc-cell w-3 h-3 rounded-full ${getServerColor(day.level)} transition-colors duration-200 hover:ring-2 hover:ring-brand-500/50 hover:z-10`}
                              data-count={day.count}
                              data-date={new Date(day.date).toLocaleDateString('es-ES', { dateStyle: 'long' })}
                          ></div>
                        )
                    ))}
                </div>
            ))
          ) : (
             Array.from({ length: 53 }).map(() => (
              <div class="flex flex-col gap-[3px]">
                  {Array.from({ length: 7 }).map(() => (
                      <div class="w-3 h-3 rounded-full bg-slate-100 animate-pulse"></div>
                  ))}
              </div>
            ))
          )}
      </div>
  </div>

  <div class="flex items-center gap-2 text-xs text-slate-400 mt-4 justify-start font-mono">
      <span>Less</span>
      <div class="w-3 h-3 rounded-full bg-slate-200/50"></div>
      <div class="w-3 h-3 rounded-full bg-brand-300"></div>
      <div class="w-3 h-3 rounded-full bg-brand-500"></div>
      <div class="w-3 h-3 rounded-full bg-brand-700"></div>
      <div class="w-3 h-3 rounded-full bg-brand-900"></div>
      <span>More</span>
  </div>
</section>

<script>
    function initLeetCodeContributions() {
        const grid = document.getElementById('lc-grid');
        const totalContainer = document.getElementById('lc-total');
        const scrollContainer = grid?.parentElement;

        function scrollToEnd() {
            if (scrollContainer) {
                requestAnimationFrame(() => {
                    setTimeout(() => {
                        scrollContainer.scrollLeft = scrollContainer.scrollWidth;
                    }, 0);
                });
            }
        }
        
        let tooltip = document.getElementById('gh-tooltip');
        let tooltipContent: HTMLElement | null = null;
        
        if (!tooltip) {
            tooltip = document.createElement('div');
            tooltip.id = 'gh-tooltip';
            tooltip.className = 'fixed z-[99999] pointer-events-none opacity-0 invisible bg-slate-900 text-white px-3 py-1.5 rounded-none text-xs font-medium shadow-xl transition-all duration-200 ease-out transform translate-x-[-50%] translate-y-[-100%]';
            tooltipContent = document.createElement('div');
            tooltip.appendChild(tooltipContent);
            const arrow = document.createElement('div');
            arrow.className = 'absolute bottom-0 left-1/2 -translate-x-1/2 translate-y-full w-0 h-0 border-l-[4px] border-l-transparent border-r-[4px] border-r-transparent border-t-[4px] border-t-slate-900';
            tooltip.appendChild(arrow);
            document.body.appendChild(tooltip);
        } else {
            tooltipContent = tooltip.firstElementChild as HTMLElement;
        }

        if (grid && tooltip && tooltipContent) {
            const onMouseEnter = (e: MouseEvent) => {
                const target = e.target as HTMLElement;
                if (target.classList.contains('lc-cell')) {
                    const count = target.getAttribute('data-count');
                    const date = target.getAttribute('data-date');
                    if (count && date && tooltipContent) {
                        tooltipContent.innerHTML = `<strong>${count}</strong> envíos <span class="text-slate-400">el ${date}</span>`;
                        tooltip!.style.visibility = 'visible';
                        tooltip!.style.opacity = '1';
                        tooltip!.classList.add('translate-y-[-100%]');
                        tooltip!.classList.remove('translate-y-[-90%]');
                        updatePosition(e);
                    }
                }
            };

            const updatePosition = (e: MouseEvent) => {
                const x = e.clientX;
                const y = e.clientY - 12; 
                tooltip!.style.left = `${x}px`;
                tooltip!.style.top = `${y}px`;
            };

            const onMouseLeave = (e: MouseEvent) => {
                const target = e.target as HTMLElement;
                if (target.classList.contains('lc-cell')) {
                    tooltip!.style.opacity = '0';
                    tooltip!.style.visibility = 'hidden';
                }
            };

            grid.addEventListener('mouseover', onMouseEnter);
            grid.addEventListener('mousemove', updatePosition);
            grid.addEventListener('mouseout', onMouseLeave);
        }
        
        // Initial scroll to end
        scrollToEnd();
    }
    document.addEventListener('astro:page-load', initLeetCodeContributions);
</script>