---
import Layout from "../../layouts/Layout.astro";
import { useTranslations } from "../../i18n/ui";

interface Props {
	lang: 'en' | 'es';
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const links = [
    { label: t('bio.link.portfolio'), url: lang === 'es' ? '/es' : '/' },
    { label: t('bio.link.blog'), url: lang === 'es' ? '/es/blog' : '/blog' },
    { label: t('bio.link.achronyme'), url: 'https://achrony.me' },
    { label: t('bio.link.github'), url: 'https://github.com/eddndev' },
    { label: t('bio.link.linkedin'), url: 'https://www.linkedin.com/in/eddndev' },
    { label: t('bio.link.x'), url: 'https://x.com/eddndev' },
];
---

<Layout title={`${t('bio.title')} - eddn.dev`}>
	<main class="relative w-full max-w-2xl mx-auto px-6 py-16 sm:py-24 min-h-[80vh] flex flex-col items-center justify-center">
        <!-- Background blob purely for aesthetic -->
        <div class="absolute inset-0 -z-10 opacity-40 pointer-events-none [mask-image:radial-gradient(closest-side,white,transparent)]">
            <canvas id="bio-canvas" class="w-full h-full"></canvas>
        </div>

        <div class="w-full flex flex-col items-center space-y-8 relative z-10 text-center">
            <div class="space-y-4">
                <div class="w-24 h-24 sm:w-32 sm:h-32 rounded-full overflow-hidden border-4 border-white shadow-xl mx-auto bg-slate-900 flex items-center justify-center">
                    <span class="text-4xl sm:text-5xl font-black text-white tracking-tighter">e.</span>
                </div>
                
                <div>
                    <h1 class="text-3xl sm:text-4xl font-black tracking-tighter text-slate-900">eddn.dev</h1>
                    <p class="text-brand-500 font-mono text-sm font-bold uppercase tracking-widest mt-2">{t('bio.role')}</p>
                </div>
            </div>

            <div class="w-full max-w-md flex flex-col gap-4 mt-8">
                {links.map(link => (
                    <a 
                        href={link.url}
                        class="group relative w-full flex items-center justify-center px-8 py-4 bg-white border-2 border-slate-200 hover:border-brand-500 rounded-2xl text-slate-900 hover:text-brand-600 font-bold transition-all duration-300 hover:shadow-lg hover:-translate-y-1"
                        target={link.url.startsWith('http') ? '_blank' : '_self'}
                        rel={link.url.startsWith('http') ? 'noopener noreferrer' : ''}
                    >
                        {link.label}
                    </a>
                ))}
            </div>
        </div>
	</main>

	<script>
		import { createRandomVisual, type VisualInstance } from "../../utils/visuals";

		let activeVisual: VisualInstance | null = null;

		function initBioVisualization() {
			const canvas = document.getElementById(
				"bio-canvas",
			) as HTMLCanvasElement;
			
			if (!canvas) return;

			if (activeVisual) {
				activeVisual.destroy();
			}

			activeVisual = createRandomVisual(canvas, "#8b5cf6"); 
			activeVisual.init();
		}

		function cleanup() {
			if (activeVisual) {
				activeVisual.destroy();
				activeVisual = null;
			}
		}

		document.addEventListener("astro:page-load", initBioVisualization);
		document.addEventListener("astro:before-swap", cleanup);
	</script>
</Layout>