---

<Layout title={`${t('bio.title')} - eddn.dev`}>
	<main class="relative w-full max-w-2xl mx-auto px-6 py-16 sm:py-24 min-h-[80vh] flex flex-col items-center justify-center">
        <!-- Background blob purely for aesthetic -->
        <div class="absolute inset-0 -z-10 opacity-40 pointer-events-none [mask-image:radial-gradient(closest-side,white,transparent)]">
            <canvas id="bio-canvas" class="w-full h-full"></canvas>
        </div>

        <div class="w-full flex flex-col items-center space-y-8 relative z-10 text-center">
            <div class="space-y-4">
                <div class="w-24 h-24 sm:w-32 sm:h-32 rounded-full overflow-hidden border-4 border-white dark:border-slate-950 shadow-xl mx-auto bg-slate-900 flex items-center justify-center">
                    <img src="https://www.gravatar.com/avatar/12a95befeeeb1620b43b8afd2e95e9fc14d6020246317c2ee59ff8ef344915d3?s=256" alt="eddn.dev profile" class="w-full h-full object-cover" />
                </div>
                
                <div>
                    <h1 class="text-3xl sm:text-4xl font-black tracking-tighter text-slate-900 dark:text-white">eddn.dev</h1>
                    <p class="text-brand-500 font-mono text-sm font-bold uppercase tracking-widest mt-2">{t('bio.role')}</p>
                </div>
            </div>

            <div class="w-full max-w-md flex flex-col gap-4 mt-8">
                {links.map(link => (
                    <a
                        href={link.url}
                        class="group relative w-full flex items-center justify-between p-6 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 border-r-4 border-r-slate-200 dark:border-r-slate-700 hover:border-r-brand-500 transition-all duration-300 hover:shadow-xl hover:-translate-y-1 rounded-none text-slate-900 dark:text-slate-100 font-bold overflow-hidden"
                        target={link.url.startsWith('http') ? '_blank' : '_self'}
                        rel={link.url.startsWith('http') ? 'noopener noreferrer' : ''}
                    >
                        <div
                            class="absolute right-6 top-1/2 -translate-y-1/2 pointer-events-none text-brand-500 opacity-[0.08] group-hover:opacity-[0.15] group-hover:scale-110 transition-all duration-500"
                            style="height: 140%;"
                            set:html={svgs[link.id]}
                        />
                        <span class="relative z-10">{link.label}</span>
                        <svg class="relative z-10 h-5 w-5 text-slate-400 group-hover:text-brand-500 group-hover:translate-x-1 transition-all duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                        </svg>
                    </a>
                ))}
            </div>
        </div>
	</main>

	<script>
		import { createRandomVisual, type VisualInstance } from "../../utils/visuals";

		let activeVisual: VisualInstance | null = null;

		function initBioVisualization() {
			const canvas = document.getElementById(
				"bio-canvas",
			) as HTMLCanvasElement;
			
			if (!canvas) return;

			if (activeVisual) {
				activeVisual.destroy();
			}

			activeVisual = createRandomVisual(canvas, "#8b5cf6");
			activeVisual.init();
		}

		function cleanup() {
			if (activeVisual) {
				activeVisual.destroy();
				activeVisual = null;
			}
		}

		document.addEventListener("astro:page-load", initBioVisualization);
		document.addEventListener("astro:before-swap", cleanup);
	</script>
</Layout>