    { label: t('bio.link.instagram'), url: 'https://instagram.com/eddn.dev', id: 'instagram' },
    { label: t('bio.link.tiktok'), url: 'https://tiktok.com/@eddndev', id: 'tiktok' },
    { label: t('bio.link.threads'), url: 'https://threads.net/@eddn.dev', id: 'threads' },
    { label: t('bio.link.x'), url: 'https://x.com/eddndev', id: 'x' },
    { label: t('bio.link.github'), url: 'https://github.com/eddndev', id: 'github' },
    { label: t('bio.link.linkedin'), url: 'https://www.linkedin.com/in/eddndev', id: 'linkedin' },
